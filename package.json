{
	"name": "wren",
	"private": true,
	"scripts": {
		"dev:mobile": "pnpm --filter @wren/mobile start",
		"build:tokens": "pnpm --filter @wren/design-tokens build",
		"test": "pnpm --filter @wren/mobile test",
		"test:tokens": "pnpm --filter @wren/design-tokens test",
		"typecheck": "pnpm -r --parallel run typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4"
	},
	"pnpm": {
		"onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "unrs-resolver"]
	},
	"packageManager": "pnpm@10.28.2",
	"engines": {
		"node": ">=24"
	},
	"dependencies": {
		"jotai": "^2.17.0"
	}
}
